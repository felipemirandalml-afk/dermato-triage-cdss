import fs from 'fs';
import { encodeFeatures } from '../engine/feature_encoder.js';
import { CLINICAL_CASES } from '../data/clinical_cases.js';
import { HARDENING_CASES } from '../data/hardening_cases_v2.js';
import { PROBABILISTIC_FEATURES } from '../engine/constants.js';

const allCases = [...CLINICAL_CASES, ...HARDENING_CASES];
const csvPath = 'd:/dermato-triage-cdss/data/training_cases_v2.csv';

// Read header to ensure alignment
let csvLines = fs.readFileSync(csvPath, 'utf8').trim().split('\n');
const header = csvLines[0].split(',');

let addedCount = 0;
// Over-sample much more (x10) to force stabilization on clinical patterns
for (let i = 0; i < 10; i++) {
    allCases.forEach(c => {
        if (!c.expected_syndrome) return;
        
        const { featureMap } = encodeFeatures(c.input);
        
        const row = header.map(col => {
            if (col === 'id') return `clinical_${c.id}_${i}`;
            if (col === 'edad') return c.input.age || 30;
            if (col === 'fototipo') return c.input.fitzpatrick || "III";
            if (col === 'target') return c.expected_syndrome;
            return featureMap[col] ? 1 : 0;
        });
        
        csvLines.push(row.join(','));
        addedCount++;
    });
}

fs.writeFileSync(csvPath, csvLines.join('\n'));
console.log(`Injected ${addedCount} copies of clinical baseline cases into ${csvPath}.`);
